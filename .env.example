# ─── OpenAI (서버 전용 — 브라우저에 노출하지 마세요) ───
# 로컬: 프로젝트 루트에 .env 로 복사 후 값 입력
# Vercel: Dashboard → Project → Settings → Environment Variables
# 필수: 종목 시트 챗·글로벌 챗·퀴즈 하이브리드 등 /api/chat 이 OpenAI 를 호출합니다.
# 다른 사용자가 "API 키" 오류를 보면 거의 항상 배포 환경에 OPENAI_API_KEY 가 없거나 만료된 경우입니다.
OPENAI_API_KEY=sk-your-key-here
# 종목 시트 챗: DuckDuckGo 웹 검색 스니펫은 서버(api/chat)에서 키 없이 호출합니다. 추가 설정 불필요.

# ─── /api/chat 의도 라우터 (lib-server/chat) ───
# 로컬: 아래 주석을 풀고 값을 넣거나, 기본(라우터 켜짐)만 쓰면 됩니다.
# Vercel: Dashboard → Project → Settings → Environment Variables 에 동일 이름으로 등록 후 재배포.
#
# CHAT_INTENT_ROUTER=false
#   → 이전 동작(단일 경로): 라우터 없이, 종목 시트면 항상 RAG 병합 + 기본 gpt-4o-mini 한 가지 흐름.
#   → 생략 시 라우터 켜짐(기본).
#
# CHAT_MODEL_DEEP=gpt-4o
#   → 심층 분석 의도(deep_analysis)일 때만 이 모델 사용. 미설정 시 gpt-4o-mini.
#   → 비용·쿼터 확인 후 프로덕션에 넣을지 결정하세요.

# ─── 선택: LangSmith (호출 추적·토큰·비용 대시보드) ───
# https://smith.langchain.com → API Keys 발급 후 서버(Vercel)·로컬 .env 에만 설정
# lib-server/openaiClient.ts 가 wrapOpenAI 적용 — /api/chat, /api/quiz/hybrid 의 OpenAI 호출이 기록됨
# LANGSMITH_API_KEY 만 있어도 추적 켜짐. 끄려면 LANGSMITH_TRACING=false
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_...
# LANGSMITH_PROJECT=my-kiki-project
# LANGSMITH_WORKSPACE_ID=...  (조직/워크스페이스가 여러 개일 때)

# ─── Supabase (본인 계정 프로젝트) ───
# 대시보드 https://supabase.com/dashboard → 프로젝트 선택 → Settings → API
# 아래 URL과 같은 프로젝트의 anon / service_role 키를 사용하세요. Vercel에도 동일 이름으로 넣으세요.
VITE_SUPABASE_URL=https://ofssebmhnseicwxjpvfk.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
# Vercel 서버리스(api/*)는 아래 이름만 등록해도 동일하게 인식합니다(프론트 VITE_* 와 병행 가능).
# SUPABASE_URL=https://ofssebmhnseicwxjpvfk.supabase.co
# SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# 기업 POI 동기화 POST /api/companies/sync 보호용(헤더 x-sync-token). 챗봇(/api/chat)·OPENAI 와 무관합니다.
COMPANY_SYNC_TOKEN=your-random-sync-token

# ─── 선택: Naver Local Search API (여의도 상장사 보강 크롤링) ───
# https://developers.naver.com/apps/ 에서 애플리케이션 생성 후 발급
# api/companies/sync: 지역 검색 보강 / 종목 시트 챗: 뉴스 검색 API — 동일 키 사용
# (검색·뉴스 API 사용을 앱 설정에서 켜야 할 수 있음)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ─── 선택: Overpass (api/companies/sync OSM 크롤) ───
# 기본값으로 de / kumi / lz4 미러를 순서대로 시도합니다. 한 URL만 쓰려면:
# OVERPASS_INTERPRETER_URL=https://overpass.kumi.systems/api/interpreter
# OVERPASS_FETCH_TIMEOUT_MS=42000
# OVERPASS_STATION_GAP_MS=500

# ─── Google OAuth (Supabase Provider 설정용 참고값) ───
# 실제 로그인 동작은 Supabase Dashboard > Authentication > Providers > Google 에서
# 아래 Client ID/Secret을 등록해야 합니다.
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# 로그인 완료 후 돌아올 앱 URL (모바일/Capacitor 환경에서 localhost 이슈 방지)
# 예: https://universal-layout-main.vercel.app/
VITE_AUTH_REDIRECT_URL=

# ─── 로컬 개발: npm run dev 시 /api 를 배포 URL로 프록시 (지도 주변 기업 API 등) ───
# 예: VITE_DEV_API_PROXY=https://universal-layout-main.vercel.app
# VITE_DEV_API_PROXY=

# ─── 선택: Capacitor / ionic 등 (localhost·capacitor 출처일 때만) ───
# 웹 브라우저에서는 window.location.origin 이 API와 동일하므로 보통 불필요.
# 네이티브 앱만 아래에 프로덕션 URL을 넣으세요.
# VITE_CHAT_API_ORIGIN=https://your-project.vercel.app

# ─── Vercel CLI (본인 계정으로 연결) ───
# 이전에 다른 계정으로 연결된 경우 .vercel 폴더를 지우고:
#   npx vercel login
#   npx vercel link
#   npx vercel deploy --prod
